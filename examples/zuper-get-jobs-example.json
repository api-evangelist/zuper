{
  "description": "Example: Get all urgent jobs scheduled for this week",
  "request": {
    "method": "GET",
    "url": "https://{dc_region}.zuperpro.com/api/jobs",
    "headers": {
      "x-api-key": "YOUR_API_KEY"
    },
    "query_parameters": {
      "page": 1,
      "count": 25,
      "sort": "ASC",
      "sort_by": "scheduled_start_time",
      "date_type": "scheduled_date",
